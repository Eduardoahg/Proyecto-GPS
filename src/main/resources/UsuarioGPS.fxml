<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.TransporteVisual">
    <children>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: #e0e0e0;" VBox.vgrow="ALWAYS">
            <content>
                <StackPane style="-fx-background-color: #cccccc;">
                    <children>
                        <Canvas fx:id="canvasGPS" height="2000.0" onMouseClicked="#seleccionarParadaMapa" width="2000.0" />
                    </children>
                </StackPane>
            </content>
        </ScrollPane>
        <HBox alignment="CENTER_LEFT" prefHeight="134.0" prefWidth="1280.0" spacing="15.0" style="-fx-background-color: #0B5563; -fx-padding: 15; -fx-background-radius: 20 20 0 0;">
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Origen:" textFill="WHITE" />
                        <TextField fx:id="txtOrigen" prefWidth="150.0" promptText="Selecciona en mapa..." style="-fx-background-radius: 10;" />
                    </children>
                </VBox>
                <VBox spacing="2.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Destino:" textFill="WHITE" />
                        <TextField fx:id="txtDestino" prefWidth="150.0" promptText="Selecciona en mapa..." style="-fx-background-radius: 10;" />
                    </children>
                </VBox>
                <VBox spacing="2.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Criterio:" textFill="WHITE" />
                        <ComboBox fx:id="cbCriterio" prefWidth="120.0" style="-fx-background-radius: 10;" />
                    </children>
                </VBox>
                <VBox spacing="2.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Algoritmo:" textFill="WHITE" />
                        <ComboBox fx:id="cbAlgoritmo" prefWidth="120.0" style="-fx-background-radius: 10;" />
                    </children>
                </VBox>
                <Button onAction="#ejecutarCalculo" style="-fx-background-color: #5299D3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="CALCULAR" />
                <Button onAction="#actualizarMapa" style="-fx-background-color: #BEB8EB; -fx-text-fill: #5E5C6C; -fx-font-weight: bold; -fx-background-radius: 10;" text="RECARGAR" />
                <TextArea fx:id="log" editable="false" prefHeight="60.0" prefWidth="250.0" style="-fx-font-family: 'Consolas'; -fx-font-size: 11px; -fx-background-radius: 10;" wrapText="true" HBox.hgrow="ALWAYS" />
                <Button onAction="#volverAlInicio" style="-fx-background-color: #5E5C6C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="INICIO" />
            </children>
        </HBox>
    </children>
</VBox>
