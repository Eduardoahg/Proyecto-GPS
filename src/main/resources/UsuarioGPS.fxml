<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.TransporteVisual">
    <children>
        <Pane style="-fx-background-color: white;">
            <children>
                <Canvas fx:id="canvasGPS" height="2000.0" onMouseClicked="#seleccionarParadaMapa" onMouseDragged="#arrastrarEnEditor" onMousePressed="#presionarEditor" width="2000.0" />
            </children>
        </Pane>

        <VBox maxHeight="-Infinity" maxWidth="800.0" prefHeight="100.0" prefWidth="800.0" spacing="10.0" style="-fx-background-color: #0B5563; -fx-background-radius: 25 25 0 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.6), 20, 0, 0, -8);" StackPane.alignment="BOTTOM_CENTER">
            <padding>
                <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
            </padding>
            <children>
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <TextField fx:id="txtOrigen" promptText="📍 Origen" style="-fx-background-radius: 8;" HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtDestino" promptText="🏁 Destino" style="-fx-background-radius: 8;" HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="cbAlgoritmo" prefWidth="120.0" promptText="Algoritmo" />
                        <ComboBox fx:id="cbCriterio" prefWidth="120.0" promptText="Criterio" />
                        <Button onAction="#ejecutarCalculo" prefHeight="35.0" prefWidth="60.0" style="-fx-background-color: #5299D3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="IR" />
                    </children>
                </HBox>
                <HBox spacing="15.0">
                    <children>
                        <TextArea fx:id="log" editable="false" prefHeight="70.0" prefWidth="400.0" style="-fx-control-inner-background: #F0F0F0; -fx-text-fill: black; -fx-font-family: 'Monospaced'; -fx-font-size: 11;" HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Button onAction="#actualizarMapa" prefWidth="85.0" style="-fx-background-color: #BEB8EB; -fx-text-fill: #5E5C6C; -fx-font-size: 10;" text="Recargar" />
                                <Button onAction="#volverAlInicio" prefWidth="85.0" style="-fx-background-color: #5E5C6C; -fx-text-fill: white; -fx-font-size: 10;" text="Menú" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
