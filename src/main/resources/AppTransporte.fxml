<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<StackPane prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.TransporteController">
    <children>
        <VBox fx:id="panelInicio" alignment="CENTER" spacing="30.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label text="SISTEMA GPS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="48.0" />
                    </font>
                </Label>
                <Button mnemonicParsing="false" onAction="#entrarAlGPS" prefHeight="60.0" prefWidth="250.0" style="-fx-background-color: #e74c3c;" text="ABRIR GPS" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Button>
            </children>
        </VBox>
        <BorderPane fx:id="panelGPS" visible="false">
            <left>
                <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: #ecf0f1; -fx-padding: 20;" BorderPane.alignment="CENTER">
                    <children>
                        <Label text="Configuración de Ruta">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtOrigen" promptText="ID Parada Origen" />
                        <TextField fx:id="txtDestino" promptText="ID Parada Destino" />
                        <ComboBox fx:id="cbCriterio" prefWidth="260.0" promptText="Seleccione Criterio" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#ejecutarCalculo" style="-fx-background-color: #2980b9;" text="Calcular Ruta Óptima" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                        <Separator prefWidth="200.0" />
                        <Label text="Resultados del Análisis">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <TextArea fx:id="log" editable="false" prefHeight="300.0" wrapText="true" />
                    </children>
                </VBox>
            </left>
            <center>
                <VBox alignment="CENTER" style="-fx-background-color: #bdc3c7;" BorderPane.alignment="CENTER">
                    <children>
                        <Canvas fx:id="canvasMapa" height="650.0" width="750.0" />
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</StackPane>